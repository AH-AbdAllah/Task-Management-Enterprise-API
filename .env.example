PORT=4000
NODE_ENV=development

# PostgreSQL Database URL (Neon Console or local)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# MongoDB (optional, set USE_MONGO=false to skip)
MONGO_URI="mongodb://localhost:27017/task_manager_logs"

# Redis (optional, set USE_REDIS=false to skip)
REDIS_URL="redis://localhost:6379"

# JWT Authentication
JWT_SECRET="your-super-secure-secret-key-here"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# MinIO (optional, set USE_MINIO=false to skip)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"
MINIO_BUCKET="task-attachments"

# Service Toggles (set to false to use local fallbacks)
USE_MONGO=false
USE_REDIS=false
USE_MINIO=false

# File Upload
MAX_FILE_SIZE=5242880
